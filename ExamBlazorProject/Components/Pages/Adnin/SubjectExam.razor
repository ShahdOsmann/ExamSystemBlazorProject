@page "/admin/subject-exam/{SubjectId:int}"
@attribute [Authorize(Roles = "Admin")]

@inject IExamService ExamService
@inject IQuestionService QuestionService
@inject IChoiceService ChoiceService
@inject NavigationManager NavigationManager

<div class="container mt-4">

    <h2 class="mb-4">📝 Exam Builder</h2>

    @if (Exam == null)
    {
        <div class="alert alert-warning">
            No exam exists for this subject.
        </div>

        <button class="btn btn-success" @onclick="CreateExam">
            ➕ Create Exam
        </button>
    }
    else
    {
        <!-- Exam Settings -->

        <div class="card shadow-sm mb-4 p-4">

            <h5 class="mb-3">Exam Settings</h5>

            <div class="row align-items-center">

                <div class="col-md-4">
                    <label class="form-label">Duration (minutes)</label>
                    <input class="form-control" type="number" @bind="Exam.Duration" />
                </div>

                <div class="col-md-2 mt-4">
                    <button class="btn btn-primary w-100" @onclick="UpdateExam">
                         Save
                    </button>
                </div>

            </div>

        </div>

        <h4 class="mb-3">Questions</h4>

        @foreach (var question in Questions)
        {
            <div class="card shadow-sm mb-4">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <strong>Question</strong>

                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => DeleteQuestion(question.Id)">
                            🗑 Delete
                        </button>
                    </div>

                    <input class="form-control mb-3"
                           placeholder="Enter question text..."
                           @bind="question.Content" />

                    <div class="ms-3">

                        @foreach (var choice in question.Choices)
                        {
                            <div class="d-flex align-items-center mb-2">

                                <input type="radio"
                                       name="correct_@question.GetHashCode()"
                                       class="form-check-input me-2"
                                       checked="@choice.IsCorrect"
                                       @onchange="() => SelectCorrect(question, choice)" />

                                <input class="form-control me-2"
                                       placeholder="Choice text..."
                                       @bind="choice.Content" />

                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => RemoveChoice(question, choice)">
                                    ✖
                                </button>

                            </div>
                        }

                    </div>

                    <div class="mt-3">

                        <button class="btn btn-sm btn-outline-primary me-2"
                                @onclick="() => AddChoice(question)">
                            ➕ Add Choice
                        </button>

                        <button class="btn btn-success"
                                @onclick="() => SaveQuestion(question)">
                             Save Question
                        </button>

                    </div>

                    @if (ValidationMessages.ContainsKey(question))
                    {
                        <div class="alert alert-danger mt-3">
                            @ValidationMessages[question]
                        </div>
                    }

                </div>

            </div>
        }

        <div class="text-center mt-4">

            <button class="btn btn-lg btn-success"
                    @onclick="Back">
                Done
            </button>

            <button class="btn btn-lg btn-primary"
                    @onclick="AddQuestion">
                ➕ Add New Question
            </button> 
        </div> 
    }

    <div class="mt-5">
        <button class="btn btn-secondary" @onclick="Back">
            ← Back to Subjects
        </button>
    </div>

</div>

@code {

    [Parameter]
    public int SubjectId { get; set; }

    private Exam? Exam;

    private List<Question> Questions = new();

    Dictionary<Question, string> ValidationMessages = new();

    protected override void OnInitialized()
    {
        LoadData();
    }

    void LoadData()
    {
        Exam = ExamService.GetExamWithQuestionsBySubject(SubjectId);

        if (Exam != null)
            Questions = Exam.Questions.ToList();
    }

    void CreateExam()
    {
        var exam = new Exam
        {
            Duration = 60,
            SubjectId = SubjectId
        };

        ExamService.AddExam(exam);

        LoadData();
    }

    void UpdateExam()
    {
        ExamService.UpdateExam(Exam);
    }

    void AddQuestion()
    {
        var q = new Question
        {
            Content = "",
            ExamId = Exam.Id,
            Choices = new List<Choice>
            {
                new Choice(),
                new Choice(),
                new Choice(),
                new Choice()
            }
        };

        Questions.Add(q);
    }

    void SaveQuestion(Question q)
    {
        var error = ValidateQuestion(q);

        if (error != null)
        {
            ValidationMessages[q] = error;
            return;
        }

        ValidationMessages.Remove(q);

        if (q.Id == 0)
            QuestionService.AddQuestion(q);
        else
            QuestionService.UpdateQuestion(q);

        foreach (var choice in q.Choices)
        {
            if (choice.Id == 0)
            {
                choice.QuestionId = q.Id;
                ChoiceService.AddChoice(choice);
            }
            else
            {
                ChoiceService.UpdateChoice(choice);
            }
        }

        LoadData();
    }

    string? ValidateQuestion(Question q)
    {
        if (string.IsNullOrWhiteSpace(q.Content))
            return "Question text cannot be empty.";

        if (q.Choices.Count < 2)
            return "Each question must have at least two choices.";

        if (q.Choices.Any(c => string.IsNullOrWhiteSpace(c.Content)))
            return "Choice text cannot be empty.";

        int correctCount = q.Choices.Count(c => c.IsCorrect);

        if (correctCount == 0)
            return "You must select one correct answer.";

        if (correctCount > 1)
            return "Only one correct answer is allowed.";

        return null;
    }

    void SelectCorrect(Question question, Choice selected)
    {
        foreach (var c in question.Choices)
            c.IsCorrect = false;

        selected.IsCorrect = true;
    }

    void DeleteQuestion(int id)
    {
        QuestionService.DeleteQuestion(id);
        LoadData();
    }

    void AddChoice(Question question)
    {
        question.Choices.Add(new Choice());
    }

    void RemoveChoice(Question question, Choice choice)
    {
        question.Choices.Remove(choice);

        if (choice.Id != 0)
            ChoiceService.DeleteChoice(choice.Id);
    }

    void Back()
    {
        NavigationManager.NavigateTo("/admin/subjects");
    }

}